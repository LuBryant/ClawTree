{
  "version": "2026-07-11.ai-schema-v3-unknown",
  "schemas": {
    "classify": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionStatus", "labels", "confidence", "sourceIds", "evidence", "needsReview"],
      "properties": {
        "decisionStatus": { "type": "string", "enum": ["known", "unknown"] },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["campus", "ai", "web3", "recap", "cooperation", "sports", "finance-literacy", "rwa", "partner", "irrelevant", "unknown"]
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["claimId", "claim", "sourceIds"],
            "properties": {
              "claimId": { "type": "string" }, "claim": { "type": "string" },
              "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        },
        "needsReview": { "type": "boolean" }
      }
    },
    "dedup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionStatus", "isDuplicate", "canonicalId", "reason", "confidence", "sourceIds", "evidence", "needsReview"],
      "properties": {
        "decisionStatus": { "type": "string", "enum": ["known", "unknown"] },
        "isDuplicate": { "type": ["boolean", "null"] },
        "canonicalId": { "type": ["string", "null"] },
        "reason": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["claimId", "claim", "sourceIds"],
            "properties": {
              "claimId": { "type": "string" }, "claim": { "type": "string" },
              "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        },
        "needsReview": { "type": "boolean" }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionStatus", "riskLevel", "riskLabels", "safeSummary", "diffSummary", "sourceIds", "evidence", "needsReview"],
      "properties": {
        "decisionStatus": { "type": "string", "enum": ["known", "unknown"] },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "unknown"] },
        "riskLabels": { "type": "array", "items": { "type": "string" } },
        "safeSummary": { "type": "string" },
        "diffSummary": { "type": "string" },
        "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["claimId", "claim", "sourceIds"],
            "properties": {
              "claimId": { "type": "string" }, "claim": { "type": "string" },
              "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        },
        "needsReview": { "type": "boolean" }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionStatus", "score", "subscores", "fitPoints", "conflicts", "missingInfo", "sourceIds", "evidence", "needsReview"],
      "properties": {
        "decisionStatus": { "type": "string", "enum": ["known", "unknown"] },
        "score": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
        "subscores": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["topic", "audience", "timing", "city", "resources", "completeness"],
          "properties": {
            "topic": { "type": "integer", "minimum": 0, "maximum": 100 },
            "audience": { "type": "integer", "minimum": 0, "maximum": 100 },
            "timing": { "type": "integer", "minimum": 0, "maximum": 100 },
            "city": { "type": "integer", "minimum": 0, "maximum": 100 },
            "resources": { "type": "integer", "minimum": 0, "maximum": 100 },
            "completeness": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        },
        "fitPoints": { "type": "array", "items": { "type": "string" } },
        "conflicts": { "type": "array", "items": { "type": "string" } },
        "missingInfo": { "type": "array", "items": { "type": "string" } },
        "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["claimId", "claim", "sourceIds"],
            "properties": {
              "claimId": { "type": "string" }, "claim": { "type": "string" },
              "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        },
        "needsReview": { "type": "boolean" }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionStatus", "tiers", "risks", "questions", "sourceIds", "evidence", "guardrails", "needsReview"],
      "properties": {
        "decisionStatus": { "type": "string", "enum": ["known", "unknown"] },
        "tiers": {
          "type": ["array", "null"],
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value", "resources", "nextStep"],
            "properties": {
              "name": { "type": "string", "enum": ["light", "medium", "deep"] },
              "value": { "type": "string" },
              "resources": { "type": "array", "items": { "type": "string" } },
              "nextStep": { "type": "string" }
            }
          }
        },
        "risks": { "type": "array", "items": { "type": "string" } },
        "questions": { "type": "array", "items": { "type": "string" } },
        "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["claimId", "claim", "sourceIds"],
            "properties": {
              "claimId": { "type": "string" }, "claim": { "type": "string" },
              "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        },
        "guardrails": {
          "type": "object",
          "additionalProperties": false,
          "required": ["noUnapprovedPrize", "noGuaranteedExposure", "humanApprovalRequired"],
          "properties": {
            "noUnapprovedPrize": { "type": "boolean" },
            "noGuaranteedExposure": { "type": "boolean" },
            "humanApprovalRequired": { "type": "boolean" }
          }
        },
        "needsReview": { "type": "boolean" }
      }
    },
    "reply": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionStatus", "intent", "confidence", "summary", "nextAction", "sourceIds", "evidence", "needsReview", "needsHumanReview"],
      "properties": {
        "decisionStatus": { "type": "string", "enum": ["known", "unknown"] },
        "intent": { "type": "string", "enum": ["positive", "question", "decline", "ooo", "unknown"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "summary": { "type": "string" },
        "nextAction": { "type": "string" },
        "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["claimId", "claim", "sourceIds"],
            "properties": {
              "claimId": { "type": "string" }, "claim": { "type": "string" },
              "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        },
        "needsReview": { "type": "boolean" },
        "needsHumanReview": { "type": "boolean" }
      }
    }
  }
}
