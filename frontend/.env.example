# Server-only AI provider settings for the Next.js assistant route.
# Copy this file to frontend/.env.local and add a real key locally.
# Never prefix the key with NEXT_PUBLIC_.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional: improves public event / hackathon registration lookup quality.
# If omitted, the assistant falls back to a no-key web search path.
BRAVE_SEARCH_API_KEY=
ASSISTANT_ENABLE_WEB_SEARCH=1

# Set to 1 only when intentionally testing deterministic RAG fallback mode.
ASSISTANT_FORCE_FALLBACK=0
