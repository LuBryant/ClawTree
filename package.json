{
  "name": "clawtree",
  "version": "0.2.0",
  "private": true,
  "description": "ClawTree — AI-driven media and campus campaign growth OS",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "install": "npm --prefix frontend ci --cache .npm-cache",
    "dev": "npm --prefix frontend run dev",
    "test": "node --test tests/*.test.mjs",
    "secret:scan:source": "node scripts/secret-scan.mjs source",
    "secret:scan:diff": "node scripts/secret-scan.mjs diff",
    "secret:scan:bundle": "node scripts/secret-scan.mjs bundle",
    "secret:scan": "node scripts/secret-scan.mjs all",
    "check": "npm run secret:scan:source && npm run secret:scan:diff && npm run test && npm --prefix frontend run check && npm run secret:scan:bundle",
    "preflight": "npm run check && npm run smoke",
    "demo": "npm --prefix frontend run dev -- --hostname 127.0.0.1",
    "smoke": "node scripts/smoke.mjs",
    "test:contracts": "npm --prefix contracts test",
    "install:contracts": "npm --prefix contracts ci --cache .npm-cache"
  }
}
