# Copy to .env for local tooling. Never commit populated secret files.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Primary web provider: Zhipu search/reader + glm-4.7 grounded answer.
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_WEB_MODEL=glm-4.7
ZHIPU_WEB_SEARCH_ENGINE=search_pro
ZHIPU_WEB_ENABLE_READER=1

# Server-only Qwen Web Search + Web Extractor configuration.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com
QWEN_WEB_SEARCH_MODEL=qwen-plus
QWEN_WEB_SCRAPE_MODEL=qwen3.5-plus
QWEN_WEB_ASSIGNED_SITES=bing.com,google.com,google.com.hk,duckduckgo.com,search.yahoo.com
QWEN_WEB_ENABLE_SCRAPING=1
ASSISTANT_ENABLE_WEB_SEARCH=1

# Django unified structured Agent runtime. Supported values: zhipu, qwen,
# deepseek, openai. Empty provider/key keeps the deterministic offline path.
CLAWTREE_AGENT_PROVIDER=zhipu
ZHIPU_MODEL=glm-4.7
QWEN_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_AGENT_MODEL=qwen-plus
CLAWTREE_AGENT_ESTIMATED_COST_MICROUSD=1000
# Provider price in micro-USD per 1,000,000 tokens; set from your account plan.
CLAWTREE_AGENT_INPUT_MICROUSD_PER_MILLION=
CLAWTREE_AGENT_OUTPUT_MICROUSD_PER_MILLION=

DJANGO_DEBUG=true
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Credential-free local default.
DATABASE_ENGINE=sqlite
SQLITE_PATH=

# Required only when DATABASE_ENGINE=mysql. Use a dedicated least-privilege user.
MYSQL_DATABASE=
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_PORT=3306

# Required only when approving real outreach sends from the Django backend.
# Without these values Django uses the console email backend for local safety.
SMTP_HOST=
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=
SMTP_PASS=
DEFAULT_FROM_EMAIL=
