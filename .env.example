# Copy to .env for local tooling. Never commit populated secret files.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

DJANGO_DEBUG=true
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Credential-free local default.
DATABASE_ENGINE=sqlite
SQLITE_PATH=

# Required only when DATABASE_ENGINE=mysql. Use a dedicated least-privilege user.
MYSQL_DATABASE=
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_PORT=3306
