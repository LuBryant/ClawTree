# Copy to .env for local tooling. Never commit populated secret files.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

DJANGO_DEBUG=true
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Credential-free local default.
DATABASE_ENGINE=sqlite
SQLITE_PATH=

# Required only when DATABASE_ENGINE=mysql. Use a dedicated least-privilege user.
MYSQL_DATABASE=
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_PORT=3306

# Required only when approving real outreach sends from the Django backend.
# Without these values Django uses the console email backend for local safety.
SMTP_HOST=
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=
SMTP_PASS=
DEFAULT_FROM_EMAIL=
