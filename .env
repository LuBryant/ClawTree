# ClawTree — 环境变量
# ===========================================================================
# 区块链 — TRON Nile Testnet (EVM-Compatible) · HTX Genesis 黑客松
# ===========================================================================
TRON_NILE_RPC_URL=https://nile.trongrid.io

# Injective Testnet（备用）
# INJECTIVE_RPC_URL=https://k8s.testnet.json-rpc.injective.network

# 部署者私钥（Hardhat 自动处理 0x 前缀）
DEPLOYER_PRIVATE_KEY=

# ===========================================================================
# 数据库 — MySQL（Django backend）
# ===========================================================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=clawtree

# ===========================================================================
# LLM 供应商（OpenAI-compatible API）
# ===========================================================================
DEEPSEEK_API_KEY=sk-64b841c7f169475eaf8e469c9ddb1c7f
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# LLM_PROVIDER=deepseek    # deepseek | qwen | openai

# ===========================================================================
# 事件采集 — 搜索配置
# ===========================================================================
# Bing Search API Key（可选，用于更稳定的搜索结果）
BING_SEARCH_API_KEY=
# 自定义搜索关键词（逗号分隔，追加到默认关键词列表）
# UNIVERSITY_SEARCH_KEYWORDS=AI Agent 高校,大模型 校园 活动
